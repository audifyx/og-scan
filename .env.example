# Helius API
REACT_APP_HELIUS_KEY=your_helius_api_key

# Alert webhooks
REACT_APP_ALERT_WEBHOOK=https://your-webhook-url.com

# Real-time data
REACT_APP_DEXSCREENER_WS=wss://api.dexscreener.com/ws
REACT_APP_BIRDEYE_API_KEY=your_birdeye_key

# Email (SendGrid or similar)
REACT_APP_EMAIL_SERVICE=sendgrid
REACT_APP_EMAIL_API_KEY=your_email_key

# Database
REACT_APP_SUPABASE_URL=your_supabase_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_key

# ML Models
REACT_APP_ML_MODEL_VERSION=v1.0
REACT_APP_ML_CONFIDENCE_THRESHOLD=0.7

# KOL Tracker (Vercel env)
HELIUS_SECRET=your_helius_api_key
SUPABASE_SERVICE_ROLE_KEY=service_role_key_for_webhook_alerts
HELIUS_WEBHOOK_SECRET=optional_shared_secret_for_webhook_auth

# --- OrbitX Curve (EVM) bonding-curve factory ---
# Platform fee recipient. Required so the shared curve factory has a fixed,
# deterministic address per chain. Set before launching curve tokens.
VITE_ORBITX_FEE_WALLET=0xYourOrbitXTreasuryAddress
# Optional: address allowed to move raised native + LP tokens into a DEX pool
# after graduation. Leave unset (0x0) to keep graduation funds locked.
VITE_ORBITX_CURVE_MIGRATOR=
# Optional: WalletConnect project id (mobile / Rabby / Robinhood via QR).
VITE_WALLETCONNECT_PROJECT_ID=
